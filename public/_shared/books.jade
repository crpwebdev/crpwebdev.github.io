.row
  .col-xs-12
    section.jumbotron#books
      h2.text-center <i class="icon-book"></i>&nbsp;Books
      br
      each book in books
        article.row(itemscope itemtype="http://schema.org/Book")
          .col-xs-8.col-xs-offset-2.col-sm-offset-0.col-sm-3
            a(href="#{book.link}" title="#{book.title}" target="_blank")
              img(src="images/#{book.image}" alt="#{book.title}" class="img-responsive" itemprop="image")
            </a>
          .col-xs-12.col-sm-9
            h2(itemprop="name") #{book.title}
            p(itemprop="description")!=book.description
            p Pages: <span itemprop="numberOfPages" class="label label-primary">#{book.pages}</span>
            if book.isbn
              <p>ISBN: <span itemprop="isbn" class="label label-primary">#{book.isbn}</span></p>
            p Buy ebook: <a href="#{book.link}" title="#{book.title}" target="_blank">#{book.lang}</a>
        hr
